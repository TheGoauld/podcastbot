# =============================================================================
# PodcastBot Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Podcast Settings ---
PODCAST_NAME="My Morning Brief"
PODCAST_AUTHOR="Your Name"
PODCAST_DESC="Daily tech briefing — AI-generated from curated articles."
PODCAST_BASE_URL=https://podcast.yourdomain.com

# --- LLM Provider (pick ONE) ---
# Option A: Ollama (free, local — recommended)
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Option B: OpenRouter (paid, cloud)
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
# OPENROUTER_MODEL=deepseek/deepseek-chat

# --- Text-to-Speech (OpenAI — required) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Matrix Chat Integration ---
MATRIX_HOMESERVER=https://matrix.yourdomain.com
MATRIX_ACCESS_TOKEN=syt_xxxxxxxxxxxxxxxxx
MATRIX_USER_ID=@podcastbot:yourdomain.com
MATRIX_ROOM_ID=!xxxxxxxxxxxxx:yourdomain.com
